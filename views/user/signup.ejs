<%- include('../partials/header') -%>
    <%- include('../partials/navbar') -%>

        <div class="container login-box">
            <div id="successMessage" class="alert danger" style="position: absolute; right: 0px;">
                <strong><%- include('../partials/flashMessages') -%></strong>
            </div>
            <div class="row">
                <div class="col-md-9 offset-md-2">
                    <h1 class="display-4"><i class="fa fa-fw fa-user-circle fa-2x"></i> Sign up </i>
                    </h1>
                    <form action="/users/signup" method="post">
                        <div class="form-group text-box">
                            <i class="fa fa-envelope" aria-hidden="true"></i>
                            <input type="email" name="email" id="email" class="form-control" placeholder="Email Adderss">
                        </div>
                        <div class="form-group text-box">
                            <i class="fa fa-user" aria-hidden="true"></i>
                            <input type="text" name="username" id="username" class="form-control" placeholder="UserName">
                        </div>
                        <div class="form-group">
                            <div class="form-row justify-content-between">
                                <div class="col-md-5 text-box">
                                    <i class="fa fa-lock" aria-hidden="true"></i>
                                    <input type="password" name="password" id="password" class="form-control" placeholder="Password">
                                </div>
                                <div class="col-md-5 text-box">
                                    <i class="fa fa-lock" aria-hidden="true"></i>
                                    <input type="password" name="confirm_password" id="confirm_password" class="form-control" placeholder="Confirm Password">
                                </div>
                            </div>
                        </div>
                        <div class="form-row text-center justify-content-center">
                            <div class="col-md-2">
                                <button type="submit" class="btn" style="background-color: darkcyan; width: 12vmin;">Sign Up</button>
                            </div>
                            <div class="col-md-2">
                                <a class="btn btn-outline-secondary" style="width: 12vmin;" href="/users/login">Login</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <%- include('../partials/footer') -%>